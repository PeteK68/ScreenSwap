<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:media="using:Windows.UI"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <media:Color x:Key="Black">#111111</media:Color>
    <media:Color x:Key="NearBlack">#1F1F1F</media:Color>
    <media:Color x:Key="DarkGrey">#2D2D2D</media:Color>
    <media:Color x:Key="MidGrey">#3A3A3A</media:Color>
    <media:Color x:Key="SoftGrey">#C8C8C8</media:Color>
    <media:Color x:Key="White">#FFFFFF</media:Color>
    <media:Color x:Key="Blue">#0078D4</media:Color>
    <media:Color x:Key="LightBlue">#4CC2FF</media:Color>
    <media:Color x:Key="DarkBlue">#006CBE</media:Color>
    <media:Color x:Key="CriticalRed">#FF99A4</media:Color>
    <media:Color x:Key="BurntOrange">#F8B869</media:Color>

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource NearBlack}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource MidGrey}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource SoftGrey}" />
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource CriticalRed}" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource LightBlue}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource DarkBlue}" />
    <SolidColorBrush x:Key="KeyVisualBackgroundBrush" Color="{StaticResource LightBlue}" />
    <SolidColorBrush x:Key="KeyVisualForegroundBrush" Color="{StaticResource Black}" />

    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="TextHeadingBrush" Color="{StaticResource SoftGrey}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource SoftGrey}" />
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource BurntOrange}" />
    <SolidColorBrush x:Key="TextInputTextBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="TextInputBackgroundBrush" Color="{StaticResource DarkGrey}" />
    <SolidColorBrush x:Key="TextInputBorderBrush" Color="{StaticResource MidGrey}" />
    <SolidColorBrush x:Key="ComboBoxChevronBrush" Color="{StaticResource SoftGrey}" />
    <SolidColorBrush x:Key="ComboBoxFocusBorderBrush" Color="{StaticResource LightBlue}" />
    <SolidColorBrush x:Key="ComboBoxItemHoverBackgroundBrush" Color="{StaticResource DarkGrey}" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="{StaticResource LightBlue}" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBackgroundBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="PrimaryButtonPressedBackgroundBrush" Color="{StaticResource DarkBlue}" />
    <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="{StaticResource LightBlue}" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="{StaticResource DarkGrey}" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBackgroundBrush" Color="{StaticResource MidGrey}" />
    <SolidColorBrush x:Key="SecondaryButtonPressedBackgroundBrush" Color="{StaticResource NearBlack}" />
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="{StaticResource MidGrey}" />
    <SolidColorBrush x:Key="MonitorPrimaryForegroundBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="MonitorPrimaryBackgroundBrush" Color="{StaticResource LightBlue}" />
    <SolidColorBrush x:Key="MonitorPrimaryBorderBrush" Color="{StaticResource LightBlue}" />
    <SolidColorBrush x:Key="MonitorSecondaryForegroundBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="MonitorSecondaryBackgroundBrush" Color="{StaticResource SoftGrey}" />
    <SolidColorBrush x:Key="MonitorSecondaryBorderBrush" Color="{StaticResource MidGrey}" />
</ResourceDictionary>
