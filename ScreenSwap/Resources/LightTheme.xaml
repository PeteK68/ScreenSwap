<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:media="using:Windows.UI"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <media:Color x:Key="White">#FFFFFF</media:Color>
    <media:Color x:Key="LightGrey">#F7F8FA</media:Color>
    <media:Color x:Key="PaleGrey">#F1F4F8</media:Color>
    <media:Color x:Key="SoftGrey">#E6EAF0</media:Color>
    <media:Color x:Key="LightBlueGrey">#CBD3DD</media:Color>
    <media:Color x:Key="SlateGrey">#6B7280</media:Color>
    <media:Color x:Key="DarkSlateGrey">#5F6B7A</media:Color>
    <media:Color x:Key="NearBlack">#111827</media:Color>
    <media:Color x:Key="Blue">#0078D4</media:Color>
    <media:Color x:Key="DarkBlue">#006CBE</media:Color>
    <media:Color x:Key="NavyBlue">#005A9E</media:Color>
    <media:Color x:Key="BurntOrange">#B45309</media:Color>
    <media:Color x:Key="CriticalRed">#C42B1C</media:Color>

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource LightGrey}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource SoftGrey}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource NearBlack}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource DarkSlateGrey}" />
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource CriticalRed}" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource NavyBlue}" />
    <SolidColorBrush x:Key="KeyVisualBackgroundBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="KeyVisualForegroundBrush" Color="{StaticResource White}" />

    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource LightGrey}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource NearBlack}" />
    <SolidColorBrush x:Key="TextHeadingBrush" Color="{StaticResource SlateGrey}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource DarkSlateGrey}" />
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource BurntOrange}" />
    <SolidColorBrush x:Key="TextInputTextBrush" Color="{StaticResource NearBlack}" />
    <SolidColorBrush x:Key="TextInputBackgroundBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="TextInputBorderBrush" Color="{StaticResource LightBlueGrey}" />
    <SolidColorBrush x:Key="ComboBoxChevronBrush" Color="{StaticResource SlateGrey}" />
    <SolidColorBrush x:Key="ComboBoxFocusBorderBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="ComboBoxItemHoverBackgroundBrush" Color="{StaticResource PaleGrey}" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBackgroundBrush" Color="{StaticResource DarkBlue}" />
    <SolidColorBrush x:Key="PrimaryButtonPressedBackgroundBrush" Color="{StaticResource NavyBlue}" />
    <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="{StaticResource NearBlack}" />
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBackgroundBrush" Color="{StaticResource PaleGrey}" />
    <SolidColorBrush x:Key="SecondaryButtonPressedBackgroundBrush" Color="{StaticResource SoftGrey}" />
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="{StaticResource LightBlueGrey}" />
    <SolidColorBrush x:Key="MonitorPrimaryForegroundBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="MonitorPrimaryBackgroundBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="MonitorPrimaryBorderBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="MonitorSecondaryForegroundBrush" Color="{StaticResource NearBlack}" />
    <SolidColorBrush x:Key="MonitorSecondaryBackgroundBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="MonitorSecondaryBorderBrush" Color="{StaticResource LightBlueGrey}" />
</ResourceDictionary>
